{
  "name": "haltija",
  "version": "1.2.7",
  "description": "Browser control for AI agents - query DOM, click, type, run JS, watch mutations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./component": {
      "import": "./dist/component.js",
      "types": "./dist/component.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./test": {
      "import": "./dist/test.js",
      "types": "./dist/test.d.ts"
    }
  },
  "bin": {
    "tosijs-dev": "./bin/tosijs-dev.mjs",
    "haltija": "./bin/tosijs-dev.mjs",
    "hj": "./bin/hj.mjs",
    "haltija-mcp-setup": "./bin/mcp-setup.mjs"
  },
  "files": [
    "dist",
    "bin",
    "docs",
    "haltija-icon.svg",
    "apps/desktop/*.js",
    "apps/desktop/renderer/*.js",
    "apps/desktop/*.html",
    "apps/desktop/*.css",
    "apps/desktop/package.json",
    "apps/desktop/resources/component.js",
    "apps/desktop/resources/icon.svg"
  ],
  "scripts": {
    "build:assets": "bun run scripts/embed-assets.ts",
    "build": "bun run scripts/build.ts",
    "build:bookmarklet": "bun run bin/build-bookmarklet.ts",
    "dev": "bun run bin/server.ts",
    "electron": "bun run build && rm -f apps/desktop/resources/haltija-server-* && cd apps/desktop && npx electron .",
    "electron:quick": "cd apps/desktop && npx electron .",
    "start": "bun run electron",
    "test": "bun test src/",
    "test:integration": "bun test tests/",
    "test:server": "bun test src/server.test.ts",
    "test:https": "bun test src/https.test.ts",
    "test:both": "bun test src/both-mode.test.ts",
    "test:e2e": "bunx playwright test",
    "test:all": "bun test src/ && bun test tests/ && bunx playwright test"
  },
  "keywords": [
    "devtools",
    "debugging",
    "websocket",
    "ai-agent",
    "browser"
  ],
  "author": "Tonio Loewald",
  "license": "Apache-2.0",
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@playwright/test": "^1.40.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "tosijs-schema": "^1.1.3"
  }
}
